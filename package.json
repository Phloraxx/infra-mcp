{
  "name": "infra-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:mcp": "npm run dev --workspace @infra-mcp/mcp-server",
    "dev:agent": "npm run dev --workspace @infra-mcp/host-agent"
  },
  "engines": {
    "node": ">=22"
  }
}
