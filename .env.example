# MCP gateway
PORT=3000
BIND_HOST=127.0.0.1
AGENT_SOCKET=/run/infra-mcp/agent.sock

# Generate a long random value and configure the same value for both services.
# Example: openssl rand -hex 32
AGENT_TOKEN=replace-with-a-long-random-secret

# Host agent
AGENT_SOCKET_MODE=0660
# Optional numeric group ID that should own the Unix socket.
# Set this to the GID added to the mcp-server container.
AGENT_SOCKET_GID=

# Docker Compose / Dokploy
INFRA_MCP_GID=999

# IMPORTANT:
# The initial MCP gateway does not implement public OAuth yet.
# Keep it private or use OpenAI Secure MCP Tunnel until OAuth is configured.
